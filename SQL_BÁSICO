    {
      "cell_type": "markdown",
      "source": [
        "<font size = '4' color =violet><u><b>1-Olvidar comillas en cadenas de texto<b/></u></font>\n",
        "\n",
        "WHERE nombre = Juan; -- ❌ Error\n",
        "\n",
        "WHERE nombre = 'Juan'; -- ✅ Correcto\n",
        "\n",
        "<font size = '4' color =violet><u><b>2-Confundir NULL con cadena vacía:<b/></u></font>\n",
        "\n",
        "WHERE columna = NULL; -- ❌ Nunca devuelve nada\n",
        "\n",
        "WHERE columna IS NULL; -- ✅ Correcto\n",
        "\n",
        "<font size = '4' color =violet><u><b>3-Usar condiciones ambiguas:<b/></u></font>\n",
